# ============================================================
# .env.example — Variables de Entorno del Proyecto
# Proyecto: The Destiny Vault / Importadora SAVS
#
# INSTRUCCIONES:
#   1. Copia este archivo a .env:  cp .env.example .env
#   2. Rellena todos los valores marcados como vacíos
#   3. NUNCA subas el archivo .env al repositorio
# ============================================================

# ─── Servidor ───
PORT=5000                              # Puerto del backend Express
NODE_ENV=development                   # development | production | test
FRONTEND_PORT=80                       # Puerto del frontend (Nginx en Docker)
BACKEND_PORT=5000                      # Puerto expuesto del backend en Docker

# ─── Base de Datos (MySQL) ───
DB_HOST=127.0.0.1                      # Host del servidor MySQL (usar 'db' en Docker)
DB_PORT=3306                           # Puerto de MySQL (por defecto 3306)
DB_NAME=SAVS_DB                        # Nombre de la base de datos
DB_USER=                               # Usuario de la BD (NO commitear)
DB_PASSWORD=                           # Contraseña de la BD (NO commitear)

# ─── Autenticación (JWT) ───
JWT_SECRET=                            # Secreto para firmar tokens JWT (mín. 32 caracteres)
JWT_EXPIRES_IN=24h                     # Duración del token (ej: 24h, 7d)

# ─── Inteligencia Artificial (Chatbot) ───
GROQ_API_KEY=                          # API Key de Groq Cloud para el chatbot IA (opcional)

# ─── Email Marketing (Resend) ───
RESEND_API_KEY=                        # API Key de Resend para envío de correos (opcional)

# ─── Docker Compose (solo para orquestación) ───
# Estas variables son leídas por docker-compose.yml
# MYSQL_ROOT_PASSWORD se deriva de DB_PASSWORD automáticamente
