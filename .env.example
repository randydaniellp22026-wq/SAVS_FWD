# ──────────────────────────────────────────────────────────
# CONFIGURACIÓN DEL SERVIDOR
# ──────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ──────────────────────────────────────────────────────────
# BASE DE DATOS (MySQL / MariaDB)
# ──────────────────────────────────────────────────────────
DB_USER=tu_usuario
DB_PASS=tu_password
DB_NAME=the_destiny_vault
DB_HOST=127.0.0.1
DB_PORT=3306

# ──────────────────────────────────────────────────────────
# SEGURIDAD Y TOKENS
# ──────────────────────────────────────────────────────────
JWT_SECRET=una_clave_secreta_muy_larga_y_segura
JWT_EXPIRES_IN=24h

